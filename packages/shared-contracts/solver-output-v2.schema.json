{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schedule-solver.local/schemas/solver-output-v2.schema.json",
  "title": "SolverOutputV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "cp_sat_status",
    "objective_value",
    "best_objective_bound",
    "gap",
    "wall_time_seconds",
    "enabled_rules",
    "rule_penalties",
    "unscheduled_lessons",
    "virtual_teachers_used",
    "virtual_rooms_used",
    "relaxed_hard_violations",
    "soft_violations",
    "data_quality_warnings",
    "rules_by_status",
    "schedule",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "status": {
      "type": "string",
      "description": "High-level run status, e.g. OK, ERROR, STUB, VALIDATED"
    },
    "cp_sat_status": {
      "type": "string",
      "description": "OR-Tools CP-SAT status, e.g. OPTIMAL, FEASIBLE, INFEASIBLE, NOT_RUN"
    },
    "objective_value": {
      "type": ["number", "null"]
    },
    "best_objective_bound": {
      "type": ["number", "null"]
    },
    "gap": {
      "type": ["number", "null"]
    },
    "wall_time_seconds": {
      "type": "number",
      "minimum": 0
    },
    "enabled_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rule_penalties": {
      "type": "array",
      "description": "Per-rule penalty contributions in the objective",
      "items": { "type": "object", "additionalProperties": true }
    },
    "unscheduled_lessons": {
      "type": "array",
      "description": "Lesson demands left unscheduled (RELAXED_HARD)",
      "items": { "type": "object", "additionalProperties": true }
    },
    "virtual_teachers_used": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "virtual_rooms_used": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "relaxed_hard_violations": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "soft_violations": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "data_quality_warnings": {
      "type": "array",
      "description": "Passthrough or augmented data-quality warnings from input",
      "items": { "type": "object", "additionalProperties": true }
    },
    "rules_by_status": {
      "type": "object",
      "description": "Rule registry buckets, e.g. enforced / stub / disabled",
      "additionalProperties": true
    },
    "schedule": {
      "type": ["object", "array", "null"],
      "description": "Normalized assignments; null in diagnostic/profile modes"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
